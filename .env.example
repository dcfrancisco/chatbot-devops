APP_NAME=local-ai-devops-assistant
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

POSTGRES_DB=devops_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/devops_assistant

LLM_PROVIDER=ollama
LLM_API_BASE_URL=http://ollama:11434/v1
LLM_API_KEY=ollama
LLM_CHAT_MODEL=llama3.1:8b
LLM_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_VERSION=0.6.5
OLLAMA_PORT=11434
EMBEDDING_DIMENSIONS=768
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1200

RETRIEVAL_TOP_K=6
RETRIEVAL_MAX_CHUNK_CHARS=1200
RETRIEVAL_CHUNK_OVERLAP=150
CONVERSATION_WINDOW_SIZE=10
INGESTION_BATCH_SIZE=16
INGESTION_RETRY_ATTEMPTS=3
INGESTION_RETRY_BACKOFF_SECONDS=1.0
INGESTION_DEFAULT_GLOB=**/*
INGESTION_MAX_CONCURRENCY=4
TOOL_EXECUTION_TIMEOUT_SECONDS=15.0
TOOL_EXECUTION_RETRY_ATTEMPTS=2
TOOL_API_INTEGRATIONS_JSON={}

JENKINS_BASE_URL=http://jenkins:8080
JENKINS_USERNAME=jenkins
JENKINS_PASSWORD=change-me
JENKINS_TIMEOUT_SECONDS=10.0
JENKINS_VERIFY_TLS=true

STREAMLIT_PORT=8501
STREAMLIT_API_BASE_URL=http://backend:8000

PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

REDIS_PORT=6379
